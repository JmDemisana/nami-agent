{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maru Desktop",
  "version": "0.0.6",
  "identifier": "io.maru.desktop.tauri",
  "build": {
    "beforeDevCommand": "node ./scripts/prepare-tauri-frontend.mjs",
    "beforeBuildCommand": "node ./scripts/prepare-tauri-frontend.mjs",
    "frontendDist": "../desktop-web-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "../public/app-icon.png"
    ]
  }
}
